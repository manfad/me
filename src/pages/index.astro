---
import Base from '../layouts/Base.astro'
import Mark from '../components/Mark.vue'
import Doodle from '../components/Doodle.vue'
import ProjectCards from '../components/ProjectCards.vue'
import RoughList from '../components/RoughList.vue'
import ContactLinks from '../components/ContactLinks.vue'
import StackChips from '../components/StackChips.vue'

const frontend = [
  { label: 'Vue', icon: '/icons/vuedotjs.svg' },
  { label: 'React', icon: '/icons/react.svg' },
  { label: 'TanStack', icon: '/icons/tanstack.svg' },
  { label: 'Next.js', icon: '/icons/nextdotjs.svg', inv: true },
  { label: 'Astro', icon: '/icons/astro.svg' },
]

const backend = [
  { label: 'Express', icon: '/icons/express.svg', inv: true },
  { label: 'Hono', icon: '/icons/hono.svg' },
  { label: 'Spring Boot', icon: '/icons/spring.svg' },
  { label: 'PostgreSQL', icon: '/icons/postgresql.svg' },
  { label: 'MySQL', icon: '/icons/mysql.svg' },
  { label: 'SQLite', icon: '/icons/sqlite.svg' },
]

const agents = [
  { label: 'Claude Code', icon: '/icons/claudecode.svg' },
  { label: 'Codex', icon: '/icons/codex.svg' },
  { label: 'Cursor', icon: '/icons/cursor.svg', inv: true },
  { label: 'Kimi', icon: '/icons/kimi.svg', inv: true },
]

const timeline = [
  '2023 — graduated from Swinburne University of Technology, Sarawak',
  '2023–2025 — programmer & IT support at Sinatech',
  '2025–now — working independently, building software and websites for local businesses',
]

const lolIcon = `<a class="icon-link" href="https://www.leagueoflegends.com" target="_blank" rel="noopener" aria-label="League of Legends"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m1.912 0 1.212 2.474v19.053L1.912 24h14.73l1.337-4.682H8.33V0ZM12 1.516c-.913 0-1.798.112-2.648.312v1.74a9.738 9.738 0 0 1 2.648-.368c5.267 0 9.536 4.184 9.536 9.348a9.203 9.203 0 0 1-2.3 6.086l-.273.954-.602 2.112c2.952-1.993 4.89-5.335 4.89-9.122C23.25 6.468 18.213 1.516 12 1.516Zm0 2.673c-.924 0-1.814.148-2.648.414v13.713h8.817a8.246 8.246 0 0 0 2.36-5.768c0-4.617-3.818-8.359-8.529-8.359zM2.104 7.312A10.858 10.858 0 0 0 .75 12.576c0 1.906.492 3.7 1.355 5.266z"/></svg></a>`

const beyond = [
  `League of Legends player for 13+ years ${lolIcon}`,
  "Serial environment tweaker — I use Neovim (btw), sometimes Cursor, and I'm currently adapting to herdr after years of tmux",
  'I pair with AI agents daily — Claude Code, Codex and Kimi',
  'Keyboard collector: my daily driver is a Kinesis Advantage2, alongside a Dygma, Sofle Plus 2, Silakka54, Corne and HHKB Studio',
]

const projects = [
  {
    name: 'TabsFlow',
    description:
      'Turn indented notes into interactive node diagrams — a cross-platform desktop app with JSON transform and real-time flow visualisation.',
    tags: ['Vue', 'TypeScript', 'Tauri'],
    link: 'https://tabsflow.vercel.app',
  },
  {
    name: 'hibsf.my',
    description:
      'Website for a Black Soldier Fly farm in Keningau, Sabah — breeding process, products and farm tours.',
    tags: ['Astro'],
    link: 'https://hibsf.my',
  },
  {
    name: 'yimei.my',
    description:
      'Website for Yimei Environment Protection Technology — industrial wastewater treatment systems, giving every drop a second life.',
    tags: ['Astro'],
    link: 'https://yimei.my',
  },
  {
    name: 'This site',
    description: 'Hand-drawn one-pager with Astro, Vue islands, roughness and rough-notation.',
    tags: ['Astro', 'Vue', 'roughness'],
    link: 'https://github.com/manfad',
  },
]
---

<Base>
  <h1 id="intro">Hey, I'm Manfred Tham</h1>

  <p>
    A <Mark client:load type="underline" color="#4467c4">fullstack developer</Mark> from
    Sabah, Malaysia, three years in —&#32;
    <Mark client:load type="highlight" color="#42b883"><b>Vue</b> is home base</Mark>, and
    I ship whole products end to end: the UI, the APIs behind it, and the databases
    underneath.
  </p>

  <p>
    Long term, I'm working toward a career as a&#32;
    <Mark client:load type="highlight" color="#ffd6a5">DX engineer</Mark> — building the
    tools and workflows that make other developers faster.
  </p>

  <h2 id="stack"><Mark client:visible type="highlight" color="#a5d8ff">Current stack</Mark></h2>
  <StackChips client:only="vue" items={frontend} />
  <StackChips client:only="vue" items={backend} />

  <p>
    Currently focused on <Mark client:visible type="underline" color="#c47bd1">coding-agent
    skills</Mark> — I work with these daily:
  </p>
  <StackChips client:only="vue" items={agents} />

  <Doodle client:only="vue" />

  <h2 id="timeline"><Mark client:visible type="highlight" color="#f5e08c">Timeline</Mark></h2>
  <RoughList client:only="vue" items={timeline} />

  <h2 id="projects"><Mark client:visible type="box" color="#4467c4">Projects</Mark></h2>
  <ProjectCards client:only="vue" projects={projects} />

  <h2 id="beyond"><Mark client:visible type="highlight" color="#b7e4c7">Beyond code</Mark></h2>
  <RoughList client:only="vue" items={beyond} />

  <Doodle client:only="vue" />

  <div id="contact">
    <p class="soft">Find me around the web, or drop me a mail:</p>
    <ContactLinks client:only="vue" />
  </div>
</Base>
