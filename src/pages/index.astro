---
import Base from '../layouts/Base.astro'
import Mark from '../components/Mark.astro'
import Doodle from '../components/Doodle.vue'
import ProjectCards from '../components/ProjectCards.vue'
import RoughList from '../components/RoughList.vue'
import ContactLinks from '../components/ContactLinks.vue'
import StackChips from '../components/StackChips.vue'

const frontend = [
  { label: 'Vue', icon: '/icons/vuedotjs.svg', href: 'https://vuejs.org' },
  { label: 'React', icon: '/icons/react.svg', href: 'https://react.dev' },
  { label: 'TanStack', icon: '/icons/tanstack.svg', href: 'https://tanstack.com' },
  { label: 'Next.js', icon: '/icons/nextdotjs.svg', inv: true, href: 'https://nextjs.org' },
  { label: 'Astro', icon: '/icons/astro.svg', href: 'https://astro.build' },
]

const backend = [
  { label: 'Express', icon: '/icons/express.svg', inv: true, href: 'https://expressjs.com' },
  { label: 'Hono', icon: '/icons/hono.svg', href: 'https://hono.dev' },
  { label: 'Spring Boot', icon: '/icons/spring.svg', href: 'https://spring.io/projects/spring-boot' },
  { label: 'PostgreSQL', icon: '/icons/postgresql.svg', href: 'https://www.postgresql.org' },
  { label: 'MySQL', icon: '/icons/mysql.svg', href: 'https://www.mysql.com' },
  { label: 'SQLite', icon: '/icons/sqlite.svg', href: 'https://sqlite.org' },
]

const agents = [
  { label: 'Claude Code', icon: '/icons/claudecode.svg', href: 'https://www.claude.com/product/claude-code' },
  { label: 'Codex', icon: '/icons/codex.svg', href: 'https://openai.com/codex' },
  { label: 'Cursor', icon: '/icons/cursor.svg', inv: true, href: 'https://cursor.com' },
  { label: 'Kimi', icon: '/icons/kimi.svg', inv: true, href: 'https://www.kimi.com' },
]

const workspace = [
  { label: 'Ghostty', icon: '/icons/ghostty.svg', inv: true, href: 'https://ghostty.org' },
  { label: 'zsh', icon: '/icons/zsh.svg', href: 'https://www.zsh.org' },
  { label: 'tmux', icon: '/icons/tmux.svg', href: 'https://github.com/tmux/tmux' },
  { label: 'Neovim', icon: '/icons/neovim.svg', href: 'https://neovim.io' },
  { label: 'dotfiles', icon: '/icons/github.svg', inv: true, href: 'https://github.com/manfad/dotfile' },
]

const keyboards = [
  'Kinesis Advantage 2 (daily driver)',
  'Dactyl Manuform',
  'Sofle Plus 2',
  'Silakka54',
  'Corne',
  'HHKB Studio',
]

const timeline = [
  '2023 — graduated from Swinburne University of Technology, Sarawak',
  '2023–2025 — programmer & IT support at Sinatech, as vendor for JAS (Sabah Water Department) and JTU (Sabah Lands & Surveys Department)',
  '2025–now — working privately as a fullstack developer, shipping systems and providing IT support',
]

const projects = [
  {
    name: 'TabsFlow',
    description:
      'Turn indented notes into interactive node diagrams — a cross-platform desktop app with JSON transform and real-time flow visualisation.',
    tags: ['Vue', 'TypeScript', 'Tauri'],
    link: 'https://tabsflow.vercel.app',
  },
  {
    name: 'flashpoint',
    description:
      'Checkpoint tool for AI-agent coding sessions — one native binary that anchors every agent turn so you can inspect or time-travel without touching git history.',
    tags: ['Rust', 'CLI', 'DX'],
    link: 'https://github.com/manfad/flashpoint',
  },
  {
    name: 'YF UI',
    description:
      'Reusable Vue 3 admin UI kit — shadcn-style components on UnoCSS, published with its own component registry.',
    tags: ['Vue', 'UnoCSS', 'shadcn registry'],
    link: 'https://yf-ui.vercel.app',
  },
  {
    name: 'hibsf.my',
    description:
      'Website for a Black Soldier Fly farm in Keningau, Sabah — breeding process, products and farm tours.',
    tags: ['Astro'],
    link: 'https://hibsf.my',
  },
  {
    name: 'yimei.my',
    description:
      'Website for Yimei Environment Protection Technology — industrial wastewater treatment systems, giving every drop a second life.',
    tags: ['Astro'],
    link: 'https://yimei.my',
  },
  {
    name: 'This site',
    description: 'Hand-drawn one-pager with Astro, Vue islands, roughness and rough-notation.',
    tags: ['Astro', 'Vue', 'roughness'],
    link: 'https://github.com/manfad',
  },
]
---

<Base>
  <h1 id="intro">Hey, I'm <Mark type="highlight" color="#ffe066">Manfred Tham</Mark></h1>

  <p>
    A <Mark type="underline" color="#4467c4">fullstack developer</Mark> from
    Sabah, Malaysia, three years in —&#32;
    <Mark type="highlight" color="#42b883"><b>Vue</b> is home base</Mark>, and
    I ship whole products end to end: the UI, the APIs behind it, and the databases
    underneath.
  </p>

  <p>
    I like building tools that enhance my workflow and kill off repetitive, annoying
    work — long term, I'm working toward a career as a&#32;
    <Mark type="highlight" color="#ffd6a5">DX engineer</Mark>, building the tools and
    workflows that make other developers faster too.
  </p>

  <p>
    Right now I'm deep in <Mark type="underline" color="#c47bd1">AI
    engineering</Mark> — building with the AI SDK, designing agent harnesses, writing
    agent skills, and sharpening my prompting. These are part of my everyday toolkit:
  </p>
  <StackChips client:only="vue" items={agents} />

  <Doodle client:only="vue" />

  <h2 id="stack"><Mark type="highlight" color="#a5d8ff">My stack</Mark></h2>
  <StackChips client:only="vue" items={frontend} />
  <StackChips client:only="vue" items={backend} />

  <Doodle client:only="vue" />

  <h2 id="timeline"><Mark type="highlight" color="#f5e08c">Timeline</Mark></h2>
  <RoughList client:only="vue" items={timeline} />

  <Doodle client:only="vue" />

  <h2 id="projects"><Mark type="box" color="#4467c4">Projects</Mark></h2>
  <ProjectCards client:only="vue" projects={projects} />

  <Doodle client:only="vue" />

  <h2 id="beyond"><Mark type="highlight" color="#b7e4c7">Fun facts about me</Mark></h2>
  <StackChips client:only="vue" label="Working environment" items={workspace} />
  <p class="soft chip-caption">Keyboard collection</p>
  <RoughList client:only="vue" items={keyboards} />

  <Doodle client:only="vue" />

  <div id="contact">
    <p class="soft">Find me around the web, or drop me a mail:</p>
    <ContactLinks client:only="vue" />
  </div>
</Base>
